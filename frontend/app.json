{
  "expo": {
    "name": "CalorieSnap",
    "slug": "caloriesnap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0A0A",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.caloriesnap.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.caloriesnap.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow CalorieSnap to access your photos to log meals.",
          "cameraPermission": "Allow CalorieSnap to take photos of your meals."
        }
      ]
    ],
    "scheme": "caloriesnap",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6c0d0949-fa38-44ef-a9c6-fee7be09cb70"
      }
    }
  }
}
